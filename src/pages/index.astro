---
import Layout from "../layouts/Layout.astro";
import BtnScroll from "../components/BtnScroll.astro";
import { mook } from "../config.ts";
import Logo from "../components/Logo.astro";
import Services from "../components/Services.astro";
---

<Layout>
  <section
    class="flex flex-col gap-8 md:gap-12 md:flex-row md:h-dvh items-center overflow-x-hidden"
  >
    <section class="flex-1">
      <article class="flex flex-col items-center justify-center gap-4 py-10">
        <Logo />
        <p class="text-blue-300 font-black px-4 text-lg">{mook.title}</p>
      </article>
      <article>
        <header>
          <h1 class="text-white text-4xl font-black p-4">
            {mook.subtitle}
          </h1>
        </header>
        <section>
          <p class="font-black px-4">
            {mook.description}
          </p>
        </section>
        <footer class="flex gap-4 items-center justify-center py-4">
          <a
            href="/account"
            type="button"
            class="z-100 py-2 px-4 border-2 border-2-white rounded-2xl bg-white text-black font-black"
          >
            {mook.buttons.primary}
          </a>
          <a
            href="/"
            type="button"
            class="z-100 py-2 px-4 border-2 border-2-white rounded-2xl text-white bg-black font-black"
          >
            {mook.buttons.secondary}
          </a>
        </footer>
      </article>
    </section>
    <section class="flex-1 flex items-center justify-center">
      <article class="flex flex-col items-center justify-center">
        <img
          alt="Primera imagen"
          src={mook.images.first_image}
          class="-translate-y-4 md:translate-y-4 md:hidden z-100"
        />
        <img
          alt="Primera imagen"
          src={mook.images.second_image}
          class="hidden md:block max-w-[620px] max-h-[310px] md:absolute z-100"
        />
        <img
          alt="Primera imagen"
          src={mook.images.fondo}
          class="absolute z-99 md:max-w-[512px] lg:max-w-[680px] xl:max-w-[840px]"
        />
      </article>
    </section>
  </section>
  <Services />
</Layout>
