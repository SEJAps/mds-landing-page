---
import {
  SignedIn,
  SignedOut,
  UserButton,
  SignInButton,
} from "@clerk/astro/components";
---

<nav>
  <aside class="flex bg-red-600">
    <a href="/">Home</a>
    <a href="/dashboard">Dashboard</a>
  </aside>
  <SignedOut>
    <SignInButton mode="modal" />
  </SignedOut>
  <SignedIn>
    <UserButton />
  </SignedIn>
</nav>

<style>
  nav {
    position: sticky;
    top: 0;
    display: flex;
    justify-content: flex-end;
    padding: 1rem;
  }
  aside {
    display: flex;
    gap: 1rem;
    align-items: center;
    padding: 0 1rem;
  }
</style>
